# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=3000

# App environment
APP_ENV=local

# Backend HTTP
LISTEN_ADDR=:3000

# CORS (mainly for local dev when the frontend runs on another origin)
# Comma-separated list. Example: http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Only enable if you intentionally use cookie-based auth.
CORS_ALLOW_CREDENTIALS=false

# Auth
JWT_SECRET=order-express-secret-change-in-production
JWT_EXPIRY_HOURS=72

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=order_express
DB_USER=order_express
DB_PASSWORD=order_express_password
DB_SSLMODE=disable

# Local-only: auto migrate + seed at server startup
DB_AUTO_MIGRATE=true
DB_AUTO_SEED=true

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache
CACHE_TTL_SECONDS=60

# Rate limit (per minute)
RL_ENABLED=true
RL_LOGIN_PER_MIN=20
RL_ORDER_CREATE_PER_MIN=30
RL_PAYMENT_PER_MIN=30
